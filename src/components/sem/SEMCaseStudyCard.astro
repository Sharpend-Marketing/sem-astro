---
import { Image } from 'astro:assets'

interface Props {
  title: string
  client: string
  category: string
  description: string
  href: string
  image: string
  logo?: string
  date?: string
  duration?: string
  layout?: 'horizontal' | 'compact'
}

const { title, client, category, description, href, image, logo, date, duration, layout = 'horizontal' } = Astro.props
const isCompact = layout === 'compact'
---

<a
  href={href}
  class="group block h-full"
>
  <article class:list={[
    'grid h-full overflow-hidden rounded-2xl bg-white shadow-card transition-all duration-300 hover:shadow-card-hover',
    !isCompact && 'md:grid-cols-5',
  ]}>
    <!-- Image -->
    <div class:list={[
      'relative h-64 overflow-hidden',
      isCompact ? 'sm:h-72' : 'md:col-span-3 md:min-h-80',
    ]}>
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      {logo && (
        <div class="absolute inset-0 flex items-center justify-center bg-teal-dark/80 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <Image src={logo} alt={client} width={320} height={160} class="h-16 w-auto max-w-[70%] object-contain brightness-0 invert" loading="lazy" />
        </div>
      )}
    </div>

    <!-- Content -->
    <div class:list={[
      'flex min-w-0 flex-col p-6 sm:p-8',
      !isCompact && 'justify-center md:col-span-2',
    ]}>
      <h2 class:list={[
        'font-accent font-medium text-heading transition-colors group-hover:text-teal-solid',
        isCompact ? 'text-h4' : 'text-h3',
      ]}>{title}</h2>
      <p class="mt-4 text-sm leading-relaxed text-text-body line-clamp-3">{description}</p>

      <!-- Metadata Row -->
      <div class:list={[
        'mt-6 grid grid-cols-2 gap-x-6 gap-y-4 border-t border-border pt-6',
        !isCompact && 'lg:grid-cols-4',
      ]}>
        <div class="min-w-0">
          <p class="text-xs font-medium uppercase tracking-wider text-text-muted">Client</p>
          <p class="mt-1 break-words text-sm font-medium leading-snug text-heading">{client}</p>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-medium uppercase tracking-wider text-text-muted">Project Type</p>
          <p class="mt-1 break-words text-sm font-medium leading-snug text-heading">{category}</p>
        </div>
        {date && (
          <div class="min-w-0">
            <p class="text-xs font-medium uppercase tracking-wider text-text-muted">Date</p>
            <p class="mt-1 break-words text-sm font-medium leading-snug text-heading">{date}</p>
          </div>
        )}
        {duration && (
          <div class="min-w-0">
            <p class="text-xs font-medium uppercase tracking-wider text-text-muted">Duration</p>
            <p class="mt-1 break-words text-sm font-medium leading-snug text-heading">{duration}</p>
          </div>
        )}
      </div>

      <!-- View Now Link -->
      <div class="mt-auto pt-6">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-teal-solid transition-colors group-hover:text-teal-dark">
          View Now
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </span>
      </div>
    </div>
  </article>
</a>
