---
interface Props {
  number: string
  title: string
  description: string
  href: string
  icon?: 'strategy' | 'digital' | 'social' | 'paid' | 'creative' | 'ai' | 'seo'
  variant?: 'default' | 'showcase'
}

const { number, title, description, href, icon = 'digital', variant = 'default' } = Astro.props

const icons = {
  strategy: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75l8.25-4.5 8.25 4.5L12 11.25l-8.25-4.5zM3.75 12l8.25 4.5 8.25-4.5M3.75 17.25l8.25 4.5 8.25-4.5" />',
  digital: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6zM13.5 3.75A7.5 7.5 0 0120.25 10.5H13.5V3.75z" />',
  social: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75m-9.75 6h9.75m-9.75 6h9.75M3.75 6h.008v.008H3.75V6zm0 6h.008v.008H3.75V12zm0 6h.008v.008H3.75V18z" />',
  paid: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84l-4.61 2.306A2.25 2.25 0 012.5 16.134V7.866a2.25 2.25 0 013.23-2.012l4.61 2.305m0 7.682l8.93 4.465A1.5 1.5 0 0021.5 18.964V5.036a1.5 1.5 0 00-2.23-1.342L10.34 8.16m0 7.68V8.16" />',
  creative: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763" />',
  ai: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />',
  seo: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.197 5.197a7.5 7.5 0 0010.606 10.606z" />',
}
---

{variant === 'showcase' ? (
  <a
    href={href}
    class="group relative flex min-h-80 flex-col overflow-hidden rounded-[32px] bg-bg-light p-8 transition-colors duration-300 hover:bg-teal focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-teal-solid"
    aria-label={`${title}: ${description}`}
  >
    <div class="relative z-10 flex items-start justify-between">
      <span class="text-h3 font-light leading-none text-border-solid transition-colors duration-300 group-hover:text-white/40">{number}</span>
      <svg class="h-5 w-5 text-teal-solid transition-colors duration-300 group-hover:text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </div>
    <svg class="pointer-events-none absolute -right-8 top-12 h-48 w-48 text-heading opacity-[0.06] transition-all duration-300 group-hover:scale-105 group-hover:text-white group-hover:opacity-15" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" aria-hidden="true">
      <Fragment set:html={icons[icon]} />
    </svg>
    <h3 class="relative z-10 mt-auto max-w-xs font-accent text-h3 font-medium leading-tight text-heading transition-colors duration-300 group-hover:text-white">
      {title}
    </h3>
  </a>
) : (
  <a
    href={href}
    class="service-card group flex flex-col rounded-[32px] bg-bg-light p-8 transition-all duration-300 hover:bg-teal"
  >
    <div class="flex items-start justify-between">
      <span class="text-h3 font-light leading-none text-border-solid transition-colors duration-300 group-hover:text-white/40">{number}</span>
      <svg class="h-5 w-5 text-teal-solid transition-colors duration-300 group-hover:text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </div>
    <h3 class="mt-6 font-accent text-h4 font-medium text-heading transition-colors duration-300 group-hover:text-white">{title}</h3>
    <p class="mt-3 text-sm leading-relaxed text-text-body transition-colors duration-300 group-hover:text-white/80">{description}</p>
    <span class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-medium text-teal-solid transition-colors duration-300 group-hover:text-white">
      Learn More
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </span>
  </a>
)}
