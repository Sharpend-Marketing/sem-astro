---
import { Image } from 'astro:assets'

interface Props {
  title: string
  description?: string
  ctaText: string
  ctaHref: string
  label?: string
  variant?: 'default' | 'stats'
}

const { title, description, ctaText, ctaHref, label = 'CONTACT US' } = Astro.props
---

<section class="px-6 py-20">
  <div class="mx-auto max-w-7xl">
    <div class="cta-card relative overflow-hidden rounded-[32px] bg-teal px-8 py-16 md:px-16 md:py-20">
      <div class="relative z-10 grid items-center gap-12 md:grid-cols-2">
        <!-- Left: Content -->
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-medium text-white backdrop-blur-sm">
            <svg class="h-4 w-4 text-teal-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
            <span class="text-teal-accent">{label}</span>
          </span>
          <h2 class="mt-6 font-accent text-h2 font-medium text-white">{title}</h2>
          {description && (
            <p class="mt-4 text-lead text-white/70">{description}</p>
          )}
          <div class="mt-8">
            <a href={ctaHref} class="inline-flex items-center gap-2 rounded-[0px_7px] bg-teal-dark px-6 py-3 text-base font-medium text-white transition-colors hover:bg-heading focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white">
              {ctaText}
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Original Discover / Create / Analyze artwork -->
        <div class="relative hidden h-72 items-center justify-center md:flex">
          <Image
            src="/images/cta/cta-img.avif"
            width={500}
            height={638}
            alt="Discover, create, and analyze"
            class="h-full w-auto object-contain"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    background-image: url('/images/brand/cta-pattern.svg');
    background-position: center;
    background-repeat: repeat;
    background-size: contain;
  }
</style>
