---
import { Image } from 'astro:assets'

interface Props {
  title: string
  description: string
  href: string
  image: string
  imageAlt: string
  icon: 'strategy' | 'digital' | 'social' | 'paid' | 'creative' | 'ai' | 'seo'
}

const { title, description, href, image, imageAlt, icon } = Astro.props

const icons = {
  strategy: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75l8.25-4.5 8.25 4.5L12 11.25l-8.25-4.5zM3.75 12l8.25 4.5 8.25-4.5M3.75 17.25l8.25 4.5 8.25-4.5" />',
  digital: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6zM13.5 3.75A7.5 7.5 0 0120.25 10.5H13.5V3.75z" />',
  social: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75m-9.75 6h9.75m-9.75 6h9.75M3.75 6h.008v.008H3.75V6zm0 6h.008v.008H3.75V12zm0 6h.008v.008H3.75V18z" />',
  paid: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84l-4.61 2.306A2.25 2.25 0 012.5 16.134V7.866a2.25 2.25 0 013.23-2.012l4.61 2.305m0 7.682l8.93 4.465A1.5 1.5 0 0021.5 18.964V5.036a1.5 1.5 0 00-2.23-1.342L10.34 8.16m0 7.68V8.16" />',
  creative: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm3.388-1.62a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763" />',
  ai: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />',
  seo: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.197 5.197a7.5 7.5 0 0010.606 10.606z" />',
}
---

<article class="grid items-center gap-8 border-b border-border py-10 last:border-b-0 lg:grid-cols-2 lg:gap-16">
  <div class="flex gap-5 lg:pl-6">
    <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-border text-teal-accent">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true">
        <Fragment set:html={icons[icon]} />
      </svg>
    </div>
    <div>
      <h3 class="font-accent text-h3 font-medium text-heading">{title}</h3>
      <p class="mt-3 max-w-lg text-body-lg leading-relaxed text-text-body">{description}</p>
      <a href={href} class="btn-sem mt-6">
        Learn More
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </div>
  <div class="aspect-square w-full max-w-md justify-self-end overflow-hidden rounded-xl bg-bg-light">
    <Image src={image} alt={imageAlt} width={720} height={720} class="h-full w-full object-cover" loading="lazy" />
  </div>
</article>
